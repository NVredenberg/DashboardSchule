{
  "name": "@server-dashboard/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:wol-relay": "tsx watch src/wolRelay.ts",
